{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "dependencyDashboard": false,
  "extends": [
    "config:recommended"
  ],
  "packageRules": [
    {
      "groupName": "all-dependencies",
      "groupSlug": "all-deps",
      "matchPackagePatterns": [
        "*"
      ]
    }
  ],
  "schedule": [
    "before 9am on monday"
  ],
  "timezone": "UTC"
}
